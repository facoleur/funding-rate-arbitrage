# --- DB ---
# Postgres (production / docker)
DATABASE_URL=postgresql+asyncpg://option_arb:option_arb@localhost:5432/option_arb
# For alembic sync driver (auto-derived if unset)
ALEMBIC_DATABASE_URL=postgresql+psycopg2://option_arb:option_arb@localhost:5432/option_arb

CONFIG_PATH=/app/config.yaml

# --- Alerter ---
BOT_TOKEN=
CHAT_ID=

# --- Deribit (OAuth client_credentials) ---
# Get from Deribit UI → Account → API → Add new key (permissions: trade:read_write)
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# --- Derive / Lyra V2 (session key signing) ---
# ⚠ NOT your Metamask/EOA address — this is your Derive SMART-CONTRACT wallet.
# Find it on app.derive.xyz/developers (testnet.derive.xyz for testnet) → "Wallet" field.
DERIVE_WALLET_ADDRESS=
# Numeric id (e.g. 30769). Auto-created on your first USDC deposit.
# Find it: (1) inspect URL / tabs on the Portfolio page, or
#          (2) run `uv run python scripts/derive_bootstrap.py --network testnet \
#                     --session-key 0x... --wallet 0x...`
DERIVE_SUBACCOUNT_ID=
# Session key private key (0x…). Register it via app.derive.xyz/developers
# → "Add session key" (admin scope, 30-day expiry recommended).
DERIVE_SESSION_PRIVATE_KEY=


# --- Aevo (EIP-712 signing key) ---
AEVO_WALLET_ADDRESS=
AEVO_ACCOUNT=
AEVO_SIGNING_KEY=
